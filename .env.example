# Copy this file to ".env" and fill in your own values.
# Never commit your real .env file.

# Which LLM backend to use: "gemini" | "groq" | "anthropic"
LLM_PROVIDER=groq

# --- Gemini (free tier, supports vision for screen analysis) ---
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash

# --- Groq (free, fast, chat only — no vision/screen analysis) ---
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# --- Anthropic (paid, optional — only needed if LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6
VISION_MODEL=claude-sonnet-4-6

# Only needed if using Porcupine for wake word detection instead of openWakeWord
PORCUPINE_ACCESS_KEY=
PORCUPINE_KEYWORD_PATH=

STT_ENGINE=faster-whisper
WHISPER_MODEL_SIZE=base.en

TTS_ENGINE=edge-tts
TTS_VOICE=en-US-AriaNeural
